	debugf("^_^ unmap_b_r =3D %d\n", r);
	after_ab =3D syscall_trace_ref2((u_int)A, (u_int)B);
	after_c =3D syscall_trace_ref2((u_int)C, (u_int)U);
	debugf("^_^ after_ab =3D %d\n", after_ab);
	debugf("^_^ after_c =3D %d\n", after_c);

